{
  "name": "@rayhanadev/verdex",
  "version": "0.1.0",
  "description": "A small, type-safe, OPA-inspired policy engine for TypeScript. Rules are typed functions; queries and calls are fully inferred. Zero runtime dependencies.",
  "keywords": [
    "abac",
    "authorization",
    "authz",
    "opa",
    "policy",
    "policy-engine",
    "rbac",
    "rules-engine",
    "standard-schema",
    "type-safe",
    "typescript"
  ],
  "homepage": "https://github.com/rayhanadev/verdex#readme",
  "bugs": {
    "url": "https://github.com/rayhanadev/verdex/issues"
  },
  "license": "MIT",
  "author": "Rayhan Noufal Arayilakath",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayhanadev/verdex.git"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "oxlint",
    "format": "oxfmt",
    "knip": "knip",
    "typecheck": "tsgo --noEmit",
    "version": "changeset version",
    "release": "bun run build && npm publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260615.1",
    "@vitest/coverage-v8": "^4.1.0",
    "knip": "^5.88.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsdown": "^0.22.0",
    "vitest": "^4.1.0",
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": "^20.19.0 || >=22.12.0"
  }
}
